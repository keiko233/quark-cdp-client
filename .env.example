# CDP (Chrome DevTools Protocol) endpoint that Playwright will connect to.
# Inside the docker-compose stack, docker-entrypoint.sh sets up a socat
# forward 127.0.0.1:CDP_FORWARD_LOCAL_PORT → CDP_FORWARD_HOST:CDP_FORWARD_PORT,
# so this stays on localhost.
CDP_URL=http://127.0.0.1:9222

# Reconnection wait time after disconnection (milliseconds).
RECONNECT_INTERVAL_MS=5000

# Log level (trace/debug/info/warn/error)
LOG_LEVEL=trace

# quark-docker manager REST API. The client calls /start before every business
# request (idempotent — restores from minimized / wakes from idle-stop), and
# exposes /manager/* passthrough routes for upstream consumers.
QUARK_MANAGER_URL=http://quark-docker:8080

# Max time to wait for Quark's CDP port to come online after /start.
# Cold-start under Wine is slow; 30 s is comfortable.
QUARK_CDP_READY_TIMEOUT_MS=30000
QUARK_CDP_READY_POLL_MS=500
